# --- General ---
APP_NAME=CardWise API
ENVIRONMENT=development
DEBUG=false

# --- API ---
API_PREFIX=/api

# --- Database ---
# SQLite (default). For a persisted absolute path use four slashes:
#   sqlite:////absolute/path/cardwise.db
DATABASE_URL=sqlite:///./cardwise.db
AUTO_CREATE_TABLES=true
AUTO_SEED=true

# --- CORS (JSON array of allowed origins) ---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Recommendation engine ---
RECOMMENDATION_RESULT_LIMIT=12

# --- Logging ---
LOG_LEVEL=INFO
