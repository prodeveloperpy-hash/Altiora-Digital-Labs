# Base URL for the backend API. In development this defaults to "/api" and is
# proxied to VITE_DEV_API_PROXY (see vite.config.ts). In production, set this to
# the deployed backend origin, e.g. https://api.cardwise.example.com/api
VITE_API_BASE_URL=/api

# Backend origin used by the Vite dev proxy (development only).
VITE_DEV_API_PROXY=http://localhost:8000

# Request timeout in milliseconds for Axios calls.
VITE_API_TIMEOUT=15000

# App display name (used in the UI shell and document titles).
VITE_APP_NAME=CardWise
